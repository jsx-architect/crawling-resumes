# OpenAI API key (ChatGPT Plus does not replace this — create at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Model: gpt-4o-mini is cheap; use gpt-4o for stronger judgment
OPENAI_MODEL=gpt-4o-mini

# PostJobFree search (URL-encoded or plain — script encodes if needed)
SEARCH_QUERY=(wang or li or lee or chen or liu or huang or yang or wu or zhao or lin or zhou or zi or cheng or ming or xiao or long or china or bietnam or philippine or singapore or tai or tailand or jin or wong or chan or lee or ng or lau or nguyen) (react or reactjs) (node or nodejs) linkedin (senior or sr)
SEARCH_LOCATION=United States
SEARCH_RADIUS=500

# Limits (407 results ≈ 41 pages of 10)
MAX_PAGES=0
MAX_RESUMES=0

# Rate limiting (ms between HTTP requests to PostJobFree)
REQUEST_DELAY_MS=800
RESUME_CONCURRENCY=2
JUDGE_DELAY_MS=500

# Output
OUTPUT_DIR=output
